# Frontend (.env.local) — copy this to .env.local for local dev
# These are NOT secrets — just local development overrides

# API base URL when running Workers locally (wrangler dev)
VITE_API_URL=http://localhost:8787

# Enable debug mode
VITE_DEBUG=false

# ── Cloudflare Pages Environment Variables ──────────────────
# Set semua ini di: Pages Dashboard → Settings → Environment variables
# WORKERS_URL = URL Workers backend (tanpa trailing slash)
# Contoh: https://sky-chat.YOUR_SUBDOMAIN.workers.dev
WORKERS_URL=https://sky-chat.YOUR_SUBDOMAIN.workers.dev
